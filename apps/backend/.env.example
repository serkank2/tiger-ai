# Kaplan backend — local environment configuration.
#
# Copy this file to `.env` in the same directory and fill in your local values.
# `.env` is gitignored and must NEVER be committed. Real environment variables, if set,
# always take precedence over values in `.env`.

# --- MySQL (durable system of record) ---
# Host / port of your local MySQL server.
KAPLAN_DB_HOST=127.0.0.1
KAPLAN_DB_PORT=3306

# MySQL credentials. Set KAPLAN_DB_PASSWORD to your local MySQL password here in `.env`
# (left blank in this example on purpose — never commit a real password).
KAPLAN_DB_USER=root
KAPLAN_DB_PASSWORD=

# Schema name. Auto-created on startup if it does not exist.
KAPLAN_DB_NAME=kaplan

# --- Optional tuning (sensible defaults applied when unset) ---
# KAPLAN_DB_POOL_SIZE=10
# KAPLAN_DB_CONNECT_RETRIES=10
# KAPLAN_DB_CONNECT_RETRY_DELAY_MS=500
# KAPLAN_DB_CONNECT_MAX_DELAY_MS=5000
