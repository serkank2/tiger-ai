# Root .env — OPTIONAL overrides for docker-compose (Compose auto-loads this file).
# Copy to `.env` only if you want to change the defaults below. Never commit `.env`.
#
# The BACKEND reads its own config from apps/backend/.env (see apps/backend/.env.example).
# Keep KAPLAN_DB_PASSWORD there in sync with MYSQL_ROOT_PASSWORD here.

# MySQL root password used by the mysql container (dev default: kaplan).
MYSQL_ROOT_PASSWORD=kaplan

# Database name auto-created by the container and used by the backend.
KAPLAN_DB_NAME=kaplan

# Host port mappings (change if 3306 / 8080 are taken).
KAPLAN_DB_PORT=3306
KAPLAN_ADMINER_PORT=8080
